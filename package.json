{
  "name": "fidepos",
  "private": true,
  "version": "1.0.0",
  "description": "Aplicación de escritorio de punto de venta para PyMEs. Permite gestionar ventas, inventario, ingresos y pérdidas con reportes claros y en tiempo real, ayudando a mejorar la eficiencia y el control financiero del negocio.",
  "author": "Eric Jared Villeda Reyes y Edwin Yair Sandoval Muciño",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:6969 && electron .\"",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "dist": "electron-builder",
    "lint": "eslint .",
    "clean": "rimraf dist releases",
    "package": "npm run clean && npm run build && electron-builder"
  },
  "build": {
    "appId": "electron-react-vite",
    "productName": "FidePOS",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "dist/fidelogo.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "nsis": {
      "installerIcon": "dist/fidelogo.ico",
      "installerHeaderIcon": "dist/fidelogo.ico",
      "uninstallDisplayName": "FidePOS",
      "license": "license.txt",
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "releases",
      "buildResources": "build"
    }
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "5.2.10",
    "@fontsource/bricolage-grotesque": "5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-table": "^8.21.3",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "i18next": "^25.7.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.554.0",
    "nodemailer": "^7.0.12",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.4.1",
    "react-router-dom": "^7.12.0",
    "recharts": "^2.15.4",
    "sql.js": "1.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animated": "^2.0.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@types/node": "24.6.0",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "9.2.1",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.22",
    "globals": "16.4.0",
    "postcss": "^8.5.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "7.1.12",
    "wait-on": "9.0.1"
  },
  "keywords": []
}
